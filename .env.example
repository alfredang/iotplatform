# ----------------------------------------------------------------------------
# Database
# ----------------------------------------------------------------------------
DATABASE_URL="postgresql://iot:iot@localhost:5432/iotplatform?schema=public"

# ----------------------------------------------------------------------------
# Auth.js / NextAuth
# Generate a secret with: openssl rand -base64 32
# ----------------------------------------------------------------------------
NEXTAUTH_SECRET="change-me-to-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"
# Auth.js v5 also reads AUTH_SECRET / AUTH_URL — keep them in sync.
AUTH_SECRET="change-me-to-a-long-random-string"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Public base URL used for sample device snippets in the wizard
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ----------------------------------------------------------------------------
# OAuth providers (optional — buttons appear only when these are set)
# ----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ----------------------------------------------------------------------------
# SMTP (optional — OTP/forgot-password emails. When unset, codes are logged
# to the server console so you can still test locally.)
# ----------------------------------------------------------------------------
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="IoT Platform <no-reply@iotplatform.local>"

# ----------------------------------------------------------------------------
# MQTT broker (used by the ingestion worker and shown in the device wizard)
# ----------------------------------------------------------------------------
MQTT_BROKER_URL="mqtt://localhost:1883"
MQTT_USERNAME=""
MQTT_PASSWORD=""
# Host:port shown to users in sample device code (no protocol prefix)
NEXT_PUBLIC_MQTT_HOST="localhost:1883"

# Mark a device OFFLINE if no telemetry received within this many seconds
DEVICE_OFFLINE_SECONDS="120"

# ----------------------------------------------------------------------------
# n8n low-code automation engine (optional — the Automations page and event
# forwarding activate automatically when these are set).
#   - N8N_BASE_URL:  your n8n instance, e.g. https://n8n.example.com
#   - N8N_API_KEY:   n8n → Settings → API → create an API key
# Platform events (telemetry/alert/device online-offline/command) are POSTed to
# the n8n Webhook URLs you configure per automation. n8n flows call back into
# /api/telemetry and /api/devices/:id/command using an account API key.
# ----------------------------------------------------------------------------
N8N_BASE_URL=""
N8N_API_KEY=""
N8N_WEBHOOK_SECRET=""
